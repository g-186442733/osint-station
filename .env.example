# OSINT 工作站 — 环境变量配置
# 复制此文件为 .env 并填入实际值

# === 147AI API（必填）===
# 在 https://api.147ai.cn 获取
API_147AI_KEY=sk-your-147ai-key-here

# === 企微推送 Webhook（必填）===
# 企业微信群机器人的 Webhook URL
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key-here

# === B站 Cookies（可选）===
# 登录B站后从浏览器获取，用于采集需要登录的内容
# 不填也能用公开 API 采集基础数据
BILIBILI_COOKIES=

# === 微博 Cookies（可选）===
# m.weibo.cn 的 cookies，用于提高采集稳定性
WEIBO_COOKIES=
